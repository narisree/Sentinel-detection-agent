// ============================================================
// Detection: Azure AD — Role assigned and removed within short time window
// Description: Detects when a user is added to an Azure AD directory role and
//              then removed from the same role within a configurable time frame.
//              Brief role assignments may indicate an attacker leveraging
//              elevated access for a specific task and cleaning up to avoid
//              detection, or an insider threat using temporary privilege escalation.
//              If confirmed malicious, investigate all actions the target account
//              performed during the window — the role may have been used to
//              modify permissions, exfiltrate data, or register applications.
// Severity: High
// Tactic: Privilege Escalation (TA0004)
// Technique: T1098.003 — Account Manipulation: Additional Cloud Roles
// DataConnector: Azure Active Directory — Audit Logs
// Table: AuditLogs
// Author: SOC Detection Engineering
// Version: 2.0
// LastModified: 2026-05-24
// ============================================================

// timerange = how far back to look; timeframe = max gap between add and remove
let timerange = 7d;
let timeframe = 4h;

AuditLogs
| where TimeGenerated > ago(timerange)
| where OperationName == "Add member to role"
| where Result == "success"
// Exclude role additions initiated by Azure AD PIM
| where Identity <> "MS-PIM"
| extend User         = tostring(TargetResources[0].userPrincipalName)
| extend Role         = tostring(parse_json(tostring(parse_json(tostring(TargetResources[0].modifiedProperties))[1].newValue)))
| extend UserWhoAdded = tostring(parse_json(tostring(InitiatedBy.user)).userPrincipalName)
| project TimeAdded=TimeGenerated, User, Role, UserWhoAdded
| join kind=inner (
    AuditLogs
    | where TimeGenerated > ago(timerange)
    | where OperationName == "Remove member from role"
    | where Result == "success"
    // Exclude role removals initiated by Azure AD PIM
    | where Identity <> "MS-PIM"
    | extend User           = tostring(TargetResources[0].userPrincipalName)
    // For removals the role name is in oldValue, not newValue
    | extend Role           = tostring(parse_json(tostring(parse_json(tostring(TargetResources[0].modifiedProperties))[1].oldValue)))
    | extend UserWhoRemoved = tostring(parse_json(tostring(InitiatedBy.user)).userPrincipalName)
    | project TimeRemoved=TimeGenerated, User, Role, UserWhoRemoved
  )
  on User, Role
| extend ['Time User Held Role'] = TimeRemoved - TimeAdded
| where ['Time User Held Role'] < timeframe
| project
    TimeAdded,
    TimeRemoved,
    ['Time User Held Role'],
    User,
    Role,
    UserWhoAdded,
    UserWhoRemoved
