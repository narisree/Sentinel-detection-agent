// ============================================================
// Detection: Office 365 — Unblocked URL clicks on emails received by account
// Description: This query identifies emails received by a specific account that
//              contained URLs, where the user clicked one or more of those URLs
//              and the URL was not blocked by Safe Links. Anchors to EmailEvents
//              (filtered to emails with URLs) joined to UrlClickEvents on
//              NetworkMessageId. Designed as a parameterised investigation query
//              for use after a potential account compromise is identified.
//              If confirmed malicious, the user may have accessed a phishing page
//              or malware delivery URL via a non-blocked Safe Links click.
// Severity: Medium
// Tactic: Initial Access (TA0001)
// Technique: T1566.002 — Phishing: Spearphishing Link
// DataConnector: Microsoft 365 Defender
// Table: EmailEvents, UrlClickEvents
// Author: SOC Detection Engineering
// Version: 2.0
// LastModified: 2026-05-24
// ============================================================
// Pattern: Multi-Table Join (Pattern 6) — EmailEvents anchor + UrlClickEvents
// KM-005 — email URL click queries anchor to EmailEvents, not UrlClickEvents
// KM-006 — use ActionType != "ClickBlocked", not == "ClickAllowed"
// LL-007 — investigation query: parameterised let, event-level output, sort by Timestamp desc

let CompromizedEmailAddress = ""; // Insert the email address of the compromised account
let Timeframe = 2d;               // Choose the best timeframe for your investigation

let EmailInformation = EmailEvents
    | where RecipientEmailAddress == CompromizedEmailAddress
    | where Timestamp > ago(Timeframe)
    | where UrlCount != "0"
    | project Timestamp, NetworkMessageId, SenderMailFromAddress,
              SenderFromAddress, SenderDisplayName, ThreatNames;

EmailInformation
| join (
    UrlClickEvents
    | where ActionType != "ClickBlocked"
    | where Workload == "Email"
    | project Timestamp, Url, IPAddress, NetworkMessageId
  ) on NetworkMessageId
| sort by Timestamp desc
