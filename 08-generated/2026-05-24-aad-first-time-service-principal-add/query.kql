// ============================================================
// Detection: Azure AD — Service principal added by first-time actor
// Description: This rule detects when a user adds a service principal to Azure AD
//              and has no prior history of performing this action in the baseline
//              window. First-time service principal additions may indicate a
//              compromised account establishing a persistent OAuth backdoor, an
//              insider threat registering an unauthorised application, or an
//              attacker creating an alternate authentication path.
//              If confirmed malicious, the attacker gains persistent access to the
//              tenant via the service principal's credentials or delegated permissions.
// Severity: Medium
// Tactic: Persistence (TA0003)
// Technique: T1136.003 — Create Account: Cloud Account
// DataConnector: Azure Active Directory — Audit Logs
// Table: AuditLogs
// Author: SOC Detection Engineering
// Version: 2.0
// LastModified: 2026-05-24
// ============================================================

// Collect all users who have performed this action in the baseline window
let knownusers =
    AuditLogs
    | where TimeGenerated > ago(90d) and TimeGenerated < ago(1d)
    | where OperationName == "Add service principal"
    | extend Actor = tostring(parse_json(tostring(InitiatedBy.user)).userPrincipalName)
    | where isnotempty(Actor)
    | distinct Actor;

// Alert on first-time actors in the detection window
AuditLogs
| where TimeGenerated > ago(1d)
| where OperationName == "Add service principal"
| extend Actor = tostring(parse_json(tostring(InitiatedBy.user)).userPrincipalName)
| where isnotempty(Actor)
| where Actor !in (knownusers)
| extend AppId = tostring(AdditionalDetails[1].value)
| project TimeGenerated, Actor, AppId
